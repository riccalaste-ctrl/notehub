# ============================================
# SUPABASE CONFIGURATION
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-replace-me
SESSION_SECRET=your-super-secret-session-key-min-32-characters
SESSION_MAX_AGE=86400
ADMIN_EMAIL=admin@notehub.local
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ALLOWED_EMAIL_DOMAIN=liceoscacchibari.it
# Optional: comma-separated external emails allowed for testing
ALLOWED_TEST_EMAILS=riccalaste@gmail.com

# ============================================
# APP CONFIGURATION
# ============================================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://notehub.example.com
# Optional server-only override for OAuth redirects. Defaults to NEXT_PUBLIC_APP_URL.
# APP_URL=https://notehub.example.com
MAX_UPLOAD_SIZE_MB=50

# ============================================
# GOOGLE DRIVE MULTI-ACCOUNT OAUTH
# ============================================
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Generate a 32+ char random value, or 32 random bytes encoded as base64/64-char hex.
GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-secret-min-32-chars

# ============================================
# ANALYTICS & MONITORING
# ============================================
# VERCEL_ANALYTICS_ID=your-analytics-id
