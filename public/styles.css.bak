:root {
  --bg: #f3f6fb;
  --surface: #ffffff;
  --surface-strong: #f8fbff;
  --surface-muted: #edf2f9;
  --ink: #0f172a;
  --muted: #475569;
  --line: #d7e2ef;
  --brand: #0f766e;
  --brand-soft: #d5f2ee;
  --accent: #ea580c;
  --accent-soft: #ffedd5;
  --blue-soft: #dbeafe;
  --shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
  --shadow-soft: 0 10px 24px rgba(15, 23, 42, 0.06);
  --radius: 18px;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  min-height: 100%;
}

body {
  font-family: Inter, "Segoe UI", system-ui, sans-serif;
  color: var(--ink);
  background:
    radial-gradient(circle at top left, rgba(14, 165, 233, 0.1), transparent 24%),
    radial-gradient(circle at top right, rgba(234, 88, 12, 0.08), transparent 20%),
    var(--bg);
}

button,
input,
select,
textarea {
  font: inherit;
  color: inherit;
}

button,
a {
  -webkit-tap-highlight-color: transparent;
}

img {
  max-width: 100%;
  display: block;
}

.hidden {
  display: none !important;
}

.app-shell,
.share-shell {
  width: min(1440px, calc(100% - 32px));
  margin: 24px auto 36px;
}

.section-band,
.subject-panel,
.content-panel,
.preview-panel,
.overlay-panel,
.share-card,
.share-error {
  background: rgba(255, 255, 255, 0.84);
  border: 1px solid rgba(215, 226, 239, 0.8);
  backdrop-filter: blur(18px);
  box-shadow: var(--shadow-soft);
}

.topbar,
.overview-band {
  border-radius: calc(var(--radius) + 2px);
  padding: 28px;
}

.topbar {
  display: flex;
  gap: 24px;
  align-items: flex-start;
  justify-content: space-between;
}

.brand-block {
  max-width: 720px;
}

.eyebrow {
  margin: 0 0 8px;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--brand);
  text-transform: uppercase;
}

h1,
h2,
h3,
p {
  margin: 0;
}

.brand-block h1 {
  font-size: 2.8rem;
  line-height: 1.02;
  margin-bottom: 12px;
}

.lede {
  font-size: 1rem;
  line-height: 1.6;
  color: var(--muted);
  max-width: 640px;
}

.topbar-actions {
  display: grid;
  grid-template-columns: minmax(260px, 360px) auto auto;
  gap: 12px;
  align-items: center;
}

.search-field {
  display: grid;
  grid-template-columns: 18px 1fr;
  align-items: center;
  gap: 10px;
  min-height: 52px;
  padding: 0 16px;
  border-radius: 14px;
  border: 1px solid var(--line);
  background: rgba(248, 251, 255, 0.95);
}

.search-field input,
label input,
label select,
label textarea {
  width: 100%;
  border: 0;
  outline: 0;
  background: transparent;
}

.search-field svg,
.primary-btn svg,
.ghost-btn svg,
.icon-btn svg {
  width: 18px;
  height: 18px;
  flex: 0 0 auto;
}

.primary-btn,
.ghost-btn,
.chip-btn,
.icon-btn,
.subject-item,
.file-card,
.back-link {
  transition:
    transform 140ms ease,
    box-shadow 140ms ease,
    border-color 140ms ease,
    background-color 140ms ease;
}

.primary-btn,
.ghost-btn {
  min-height: 52px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 0 18px;
  border-radius: 14px;
  border: 1px solid transparent;
  text-decoration: none;
  cursor: pointer;
  white-space: nowrap;
}

.primary-btn {
  color: #fff;
  background: linear-gradient(135deg, #0f766e, #2563eb);
  box-shadow: 0 14px 28px rgba(37, 99, 235, 0.18);
}

.ghost-btn {
  background: rgba(255, 255, 255, 0.9);
  border-color: var(--line);
}

.primary-btn:hover,
.ghost-btn:hover,
.chip-btn:hover,
.icon-btn:hover,
.subject-item:hover,
.file-card:hover,
.back-link:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-soft);
}

.overview-band {
  margin-top: 18px;
  display: grid;
  gap: 22px;
}

.metric-strip {
  display: grid;
  gap: 14px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.metric-card {
  padding: 18px;
  border-radius: 16px;
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(237, 242, 249, 0.9));
  border: 1px solid rgba(215, 226, 239, 0.95);
}

.metric-card strong {
  display: block;
  margin-top: 10px;
  font-size: 1.85rem;
}

.metric-label {
  color: var(--muted);
  font-size: 0.95rem;
}

.overview-copy {
  display: flex;
  gap: 24px;
  align-items: end;
  justify-content: space-between;
}

.overview-copy h2 {
  font-size: 1.65rem;
  margin-top: 6px;
}

.limit-pill {
  align-self: center;
  padding: 12px 14px;
  border-radius: 14px;
  background: var(--accent-soft);
  color: #9a3412;
  font-weight: 600;
}

.workspace {
  margin-top: 18px;
  display: grid;
  grid-template-columns: 270px minmax(0, 1fr) 360px;
  gap: 18px;
  align-items: start;
}

.subject-panel,
.content-panel,
.preview-panel {
  border-radius: var(--radius);
}

.subject-panel,
.preview-panel {
  padding: 22px;
  position: sticky;
  top: 18px;
}

.content-panel {
  padding: 22px;
}

.panel-heading,
.content-toolbar,
.overlay-head,
.section-title-row,
.preview-topline,
.share-head,
.admin-toolbar {
  display: flex;
  gap: 16px;
  align-items: center;
  justify-content: space-between;
}

.subject-list {
  margin-top: 18px;
  display: grid;
  gap: 10px;
}

.subject-item {
  width: 100%;
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 12px;
  padding: 14px;
  border-radius: 16px;
  border: 1px solid var(--line);
  background: rgba(255, 255, 255, 0.86);
  text-align: left;
  cursor: pointer;
}

.subject-item.is-active {
  border-color: rgba(15, 118, 110, 0.42);
  background: linear-gradient(135deg, rgba(213, 242, 238, 0.9), rgba(255, 255, 255, 0.96));
}

.subject-dot,
.subject-swatch {
  width: 14px;
  height: 14px;
  border-radius: 999px;
  margin-top: 4px;
}

.subject-meta strong,
.file-card-title {
  display: block;
  font-size: 0.98rem;
  line-height: 1.4;
}

.subject-meta span,
.results-label,
.preview-description,
.meta-list dt,
.meta-list dd,
.share-description,
.file-meta,
.file-description {
  color: var(--muted);
}

.subject-count {
  min-width: 34px;
  min-height: 34px;
  padding: 0 8px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted);
  font-size: 0.9rem;
  font-weight: 700;
}

.content-toolbar {
  flex-wrap: wrap;
}

.sort-group {
  display: inline-flex;
  gap: 10px;
  flex-wrap: wrap;
}

.chip-btn,
.icon-btn {
  border: 1px solid var(--line);
  background: rgba(255, 255, 255, 0.9);
  cursor: pointer;
}

.chip-btn {
  min-height: 42px;
  padding: 0 14px;
  border-radius: 999px;
}

.chip-btn.is-active {
  background: var(--brand-soft);
  border-color: rgba(15, 118, 110, 0.42);
  color: #115e59;
}

.file-grid {
  margin-top: 18px;
  display: grid;
  gap: 14px;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
}

.file-card {
  padding: 18px;
  border-radius: 18px;
  border: 1px solid var(--line);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 251, 255, 0.94));
  cursor: pointer;
}

.file-card.is-selected {
  border-color: rgba(37, 99, 235, 0.4);
  box-shadow: 0 16px 30px rgba(37, 99, 235, 0.09);
}

.card-topline,
.card-actions,
.file-badges,
.preview-actions,
.share-actions,
.subject-row-actions {
  display: flex;
  gap: 10px;
  align-items: center;
}

.card-topline {
  justify-content: space-between;
}

.subject-badge,
.type-badge {
  display: inline-flex;
  align-items: center;
  min-height: 28px;
  padding: 0 10px;
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 700;
}

.type-badge {
  background: var(--blue-soft);
  color: #1d4ed8;
}

.file-card-title {
  margin-top: 12px;
  min-height: 44px;
}

.file-description {
  margin-top: 10px;
  min-height: 42px;
  font-size: 0.95rem;
  line-height: 1.45;
}

.file-meta {
  margin-top: 14px;
  display: grid;
  gap: 6px;
  font-size: 0.9rem;
}

.card-actions {
  margin-top: 18px;
  justify-content: space-between;
}

.card-link {
  color: var(--brand);
  font-weight: 700;
  text-decoration: none;
}

.icon-btn {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: inherit;
  text-decoration: none;
}

.preview-empty,
.preview-content {
  min-height: 560px;
}

.preview-empty {
  display: grid;
  align-content: center;
  gap: 12px;
}

.preview-content h2 {
  margin-top: 14px;
  font-size: 1.45rem;
}

.preview-description,
.share-description {
  margin-top: 10px;
  line-height: 1.6;
}

.preview-frame,
.share-preview {
  margin-top: 18px;
  min-height: 360px;
  border-radius: 18px;
  border: 1px solid var(--line);
  background:
    linear-gradient(180deg, rgba(248, 251, 255, 0.95), rgba(237, 242, 249, 0.96));
  overflow: hidden;
}

.preview-frame iframe,
.share-preview iframe,
.preview-frame img,
.share-preview img {
  width: 100%;
  height: 100%;
  min-height: 360px;
  border: 0;
  object-fit: contain;
  background: #fff;
}

.preview-frame pre,
.share-preview pre {
  margin: 0;
  min-height: 360px;
  padding: 22px;
  overflow: auto;
  white-space: pre-wrap;
  font-family: "Cascadia Code", Consolas, monospace;
  font-size: 0.92rem;
  line-height: 1.55;
}

.preview-placeholder {
  min-height: 360px;
  display: grid;
  place-items: center;
  padding: 26px;
  text-align: center;
  color: var(--muted);
}

.meta-list {
  margin-top: 18px;
  display: grid;
  gap: 14px;
}

.meta-list-inline {
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
}

.meta-list div {
  padding: 14px;
  border-radius: 16px;
  border: 1px solid var(--line);
  background: rgba(255, 255, 255, 0.8);
}

.meta-list dt {
  font-size: 0.82rem;
  text-transform: uppercase;
  font-weight: 700;
}

.meta-list dd {
  margin: 8px 0 0;
  font-size: 0.96rem;
}

.empty-state {
  margin-top: 18px;
  padding: 26px;
  border-radius: 18px;
  border: 1px dashed var(--line);
  background: rgba(255, 255, 255, 0.62);
}

.overlay {
  position: fixed;
  inset: 0;
  z-index: 20;
  padding: 24px 16px;
  background: rgba(15, 23, 42, 0.48);
  display: grid;
  place-items: center;
}

.overlay-panel {
  width: min(760px, 100%);
  max-height: calc(100vh - 48px);
  overflow: auto;
  border-radius: 24px;
  padding: 24px;
}

.overlay-panel-wide {
  width: min(1200px, 100%);
}

.form-grid,
.admin-login-form,
.subject-create-form,
.storage-account-form {
  display: grid;
  gap: 16px;
}

.form-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 20px;
}

label {
  display: grid;
  gap: 10px;
}

label span {
  font-size: 0.92rem;
  font-weight: 700;
}

label input,
label select,
label textarea {
  min-height: 52px;
  padding: 14px 16px;
  border-radius: 14px;
  border: 1px solid var(--line);
  background: rgba(248, 251, 255, 0.95);
}

label textarea {
  min-height: 110px;
  resize: vertical;
}

.file-input small {
  color: var(--muted);
}

.full-width {
  grid-column: 1 / -1;
}

.form-actions {
  display: flex;
  gap: 12px;
  justify-content: flex-end;
}

.admin-login-view {
  min-height: 260px;
  display: grid;
  place-items: center;
}

.admin-login-form {
  width: min(420px, 100%);
}

.admin-toolbar {
  padding-bottom: 18px;
  border-bottom: 1px solid var(--line);
}

.admin-toolbar p {
  font-weight: 700;
}

.admin-layout {
  margin-top: 22px;
  display: grid;
  grid-template-columns: 1.05fr 1fr 1.15fr;
  gap: 18px;
}

.admin-section {
  padding: 22px;
  border-radius: 20px;
  background: rgba(248, 251, 255, 0.75);
  border: 1px solid rgba(215, 226, 239, 0.9);
}

.subject-create-form {
  margin-top: 18px;
  grid-template-columns: 1fr auto auto;
  align-items: end;
}

.storage-account-form {
  margin-top: 18px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.subject-admin-list,
.file-admin-list,
.storage-account-list {
  margin-top: 18px;
  display: grid;
  gap: 12px;
  max-height: 560px;
  overflow: auto;
  padding-right: 4px;
}

.subject-admin-row,
.storage-account-card,
.file-admin-card {
  padding: 14px;
  border-radius: 18px;
  border: 1px solid var(--line);
  background: rgba(255, 255, 255, 0.92);
}

.subject-admin-row {
  display: grid;
  gap: 12px;
}

.storage-account-card {
  display: grid;
  gap: 12px;
}

.subject-admin-head {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 12px;
  align-items: center;
}

.subject-config-grid {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 12px;
}

.subject-admin-row input[type="text"] {
  min-height: 44px;
}

.subject-row-actions {
  justify-content: flex-end;
  flex-wrap: wrap;
}

.small-btn,
.danger-btn {
  min-height: 40px;
  padding: 0 12px;
  border-radius: 12px;
  border: 1px solid var(--line);
  background: #fff;
  cursor: pointer;
}

.danger-btn {
  border-color: rgba(239, 68, 68, 0.24);
  background: #fef2f2;
  color: #b91c1c;
}

.file-admin-card {
  display: grid;
  gap: 12px;
}

.file-admin-grid {
  display: grid;
  grid-template-columns: 1fr 180px;
  gap: 12px;
}

.file-admin-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
}

.toast {
  position: fixed;
  right: 18px;
  bottom: 18px;
  max-width: 320px;
  z-index: 30;
  padding: 14px 16px;
  border-radius: 16px;
  color: #fff;
  background: rgba(15, 23, 42, 0.92);
  box-shadow: var(--shadow);
}

.share-page {
  min-height: 100vh;
  display: grid;
}

.back-link {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  border-radius: 14px;
  border: 1px solid var(--line);
  text-decoration: none;
  background: rgba(255, 255, 255, 0.92);
  color: inherit;
  width: fit-content;
}

.share-card,
.share-error {
  margin-top: 18px;
  border-radius: 24px;
  padding: 28px;
}

.share-head {
  align-items: start;
}

.share-head h1 {
  margin-top: 12px;
  font-size: 2.2rem;
}

.share-actions {
  flex-wrap: wrap;
}

.share-error {
  text-align: center;
}

@media (max-width: 1180px) {
  .workspace {
    grid-template-columns: 250px minmax(0, 1fr);
  }

  .preview-panel {
    grid-column: 1 / -1;
    position: static;
  }

  .preview-empty,
  .preview-content {
    min-height: 420px;
  }
}

@media (max-width: 980px) {
  .topbar,
  .overview-copy,
  .panel-heading,
  .content-toolbar,
  .share-head,
  .admin-toolbar {
    flex-direction: column;
    align-items: stretch;
  }

  .topbar-actions,
  .subject-create-form,
  .file-admin-grid {
    grid-template-columns: 1fr;
  }

  .workspace,
  .admin-layout,
  .storage-account-form,
  .subject-config-grid {
    grid-template-columns: 1fr;
  }

  .subject-panel,
  .preview-panel {
    position: static;
  }
}

@media (max-width: 720px) {
  .app-shell,
  .share-shell {
    width: min(100% - 20px, 1440px);
    margin: 12px auto 24px;
  }

  .topbar,
  .overview-band,
  .content-panel,
  .subject-panel,
  .preview-panel,
  .overlay-panel,
  .share-card,
  .share-error {
    padding: 18px;
  }

  .brand-block h1,
  .share-head h1 {
    font-size: 2rem;
  }

  .metric-strip,
  .form-grid {
    grid-template-columns: 1fr;
  }

  .file-grid {
    grid-template-columns: 1fr;
  }

  .form-actions,
  .share-actions,
  .subject-row-actions,
  .file-admin-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .primary-btn,
  .ghost-btn,
  .small-btn,
  .danger-btn {
    width: 100%;
  }
}
