# ============================================
# SUPABASE CONFIGURATION
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-replace-me
SESSION_SECRET=your-super-secret-session-key-min-32-characters
SESSION_MAX_AGE=86400
ADMIN_EMAIL=admin@notehub.local
# Generate with: npx bcryptjs hash "YourSecurePassword123"
ADMIN_PASSWORD_HASH=$2a$10$abcdefghijklmnopqrstuvwxyz1234567890

# ============================================
# APP CONFIGURATION
# ============================================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://notehub.example.com
MAX_UPLOAD_SIZE_MB=50

# ============================================
# GOOGLE DRIVE (FASE 2 - Futuro)
# ============================================
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={}
# GOOGLE_DRIVE_ADMIN_FOLDER_ID=your-folder-id

# ============================================
# ANALYTICS & MONITORING
# ============================================
# VERCEL_ANALYTICS_ID=your-analytics-id