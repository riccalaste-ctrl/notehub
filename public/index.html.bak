<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Drive Materie</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <script type="module" src="/assets/app.js" defer></script>
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar section-band">
        <div class="brand-block">
          <p class="eyebrow">Archivio condiviso del liceo</p>
          <h1>Drive Materie</h1>
          <p class="lede">
            Appunti, verifiche e dispense ordinati per materia. Nessun account per chi consulta, upload diretto sui Drive collegati.
          </p>
        </div>

        <div class="topbar-actions">
          <label class="search-field">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M21 21l-4.35-4.35m1.35-5.15a6.5 6.5 0 11-13 0a6.5 6.5 0 0113 0z"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.7"
              />
            </svg>
            <input id="search-input" type="search" placeholder="Cerca un appunto, una verifica, una dispensa..." />
          </label>

          <button id="open-upload" class="primary-btn" type="button">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12 16V5m0 0l-4 4m4-4l4 4M5 19h14"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.8"
              />
            </svg>
            <span>Carica</span>
          </button>

          <button id="open-admin" class="ghost-btn" type="button">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12 15.5A3.5 3.5 0 1012 8.5a3.5 3.5 0 000 7zm7-3.5l-1.6-.93a5.92 5.92 0 00-.36-.86l.46-1.8l-1.77-1.02l-1.34 1.27a6.9 6.9 0 00-.93-.15L12 5l-2.33 2.51c-.32.03-.63.08-.93.15L7.4 6.39L5.63 7.4l.46 1.8c-.14.28-.26.57-.36.86L4.13 12l1.6.93c.09.3.21.59.36.87l-.46 1.8l1.77 1.02l1.34-1.27c.3.07.61.12.93.15L12 19l2.33-2.5c.32-.03.63-.08.93-.15l1.34 1.27l1.77-1.02l-.46-1.8c.15-.28.27-.57.36-.87L19 12z"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.3"
              />
            </svg>
            <span id="open-admin-label">Admin</span>
          </button>
        </div>
      </header>

      <section class="overview-band section-band">
        <div class="metric-strip">
          <article class="metric-card">
            <span class="metric-label">Materie</span>
            <strong id="metric-subjects">0</strong>
          </article>
          <article class="metric-card">
            <span class="metric-label">File condivisi</span>
            <strong id="metric-files">0</strong>
          </article>
          <article class="metric-card">
            <span class="metric-label">Archivio totale</span>
            <strong id="metric-size">0 B</strong>
          </article>
        </div>

        <div class="overview-copy">
          <div>
            <p class="eyebrow">Pensato per la classe</p>
            <h2>Un drive scolastico semplice da usare e pulito da gestire.</h2>
          </div>
          <p id="limit-pill" class="limit-pill"></p>
        </div>
      </section>

      <div class="workspace">
        <aside class="subject-panel">
          <div class="panel-heading">
            <div>
              <p class="eyebrow">Navigazione</p>
              <h2>Materie</h2>
            </div>
          </div>
          <div id="subject-list" class="subject-list"></div>
        </aside>

        <main class="content-panel">
          <section class="content-toolbar">
            <div class="sort-group" role="tablist" aria-label="Ordina file">
              <button class="chip-btn is-active" data-sort="recent" type="button">Recenti</button>
              <button class="chip-btn" data-sort="title" type="button">A-Z</button>
              <button class="chip-btn" data-sort="downloads" type="button">Scaricati</button>
            </div>
            <p id="results-label" class="results-label"></p>
          </section>

          <section id="file-grid" class="file-grid" aria-live="polite"></section>
          <section id="empty-state" class="empty-state hidden">
            <h3>Nessun file in vista</h3>
            <p>Prova a cambiare materia o a caricare i primi appunti di questa sezione.</p>
          </section>
        </main>

        <aside class="preview-panel">
          <div id="preview-empty" class="preview-empty">
            <p class="eyebrow">Anteprima</p>
            <h2>Seleziona un file</h2>
            <p>Qui compariranno i dettagli, il link diretto e la lettura rapida degli appunti.</p>
          </div>

          <div id="preview-content" class="preview-content hidden">
            <div class="preview-topline">
              <span id="preview-subject-badge" class="subject-badge"></span>
              <div class="preview-actions">
                <button id="copy-preview-link" class="icon-btn" type="button" title="Copia link">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M10 13a5 5 0 007.07 0l1.41-1.41a5 5 0 00-7.07-7.07L10.5 5.43m3 5.57a5 5 0 00-7.07 0L5.02 12.4a5 5 0 107.07 7.07L13.5 18.06"
                      fill="none"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.7"
                    />
                  </svg>
                </button>
                <a id="preview-download" class="icon-btn" href="#" title="Scarica file">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M12 3v11m0 0l4-4m-4 4l-4-4M5 19h14"
                      fill="none"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.8"
                    />
                  </svg>
                </a>
              </div>
            </div>

            <h2 id="preview-title"></h2>
            <p id="preview-description" class="preview-description"></p>
            <div id="preview-frame" class="preview-frame"></div>
            <dl class="meta-list">
              <div>
                <dt>File</dt>
                <dd id="preview-name"></dd>
              </div>
              <div>
                <dt>Dimensione</dt>
                <dd id="preview-size"></dd>
              </div>
              <div>
                <dt>Caricato</dt>
                <dd id="preview-date"></dd>
              </div>
              <div>
                <dt>Download</dt>
                <dd id="preview-download-count"></dd>
              </div>
            </dl>
          </div>
        </aside>
      </div>
    </div>

    <div id="upload-overlay" class="overlay hidden" role="dialog" aria-modal="true" aria-labelledby="upload-title">
      <div class="overlay-panel">
        <div class="overlay-head">
          <div>
            <p class="eyebrow">Condivisione</p>
            <h2 id="upload-title">Carica un file</h2>
          </div>
          <button class="icon-btn overlay-close" data-close-overlay="upload-overlay" type="button" title="Chiudi">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
            </svg>
          </button>
        </div>

        <form id="upload-form" class="form-grid">
          <label>
            <span>Titolo</span>
            <input name="title" type="text" maxlength="120" required placeholder="Es. Appunti Rivoluzione francese" />
          </label>
          <label>
            <span>Materia</span>
            <select id="upload-subject" name="subjectId" required></select>
          </label>
          <label class="full-width">
            <span>Descrizione</span>
            <textarea name="description" maxlength="280" rows="3" placeholder="Argomento, classe, capitolo o note utili"></textarea>
          </label>
          <label class="full-width file-input">
            <span>Documento</span>
            <input
              name="file"
              type="file"
              accept=".pdf,.txt,.md,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.png,.jpg,.jpeg,.webp,.zip"
              required
            />
            <small id="upload-limit-note"></small>
          </label>
          <div class="full-width form-actions">
            <button class="ghost-btn" data-close-overlay="upload-overlay" type="button">Annulla</button>
            <button id="submit-upload" class="primary-btn" type="submit">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M12 16V5m0 0l-4 4m4-4l4 4M5 19h14"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.8"
                />
              </svg>
              <span>Pubblica file</span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <div id="admin-overlay" class="overlay hidden" role="dialog" aria-modal="true" aria-labelledby="admin-title">
      <div class="overlay-panel overlay-panel-wide">
        <div class="overlay-head">
          <div>
            <p class="eyebrow">Gestione interna</p>
            <h2 id="admin-title">Area admin</h2>
          </div>
          <button class="icon-btn overlay-close" data-close-overlay="admin-overlay" type="button" title="Chiudi">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
            </svg>
          </button>
        </div>

        <section id="admin-login-view" class="admin-login-view">
          <form id="admin-login-form" class="admin-login-form">
            <label>
              <span>Codice admin</span>
              <input name="code" type="password" autocomplete="current-password" required placeholder="Inserisci il codice di gestione" />
            </label>
            <button class="primary-btn" type="submit">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M12 15.5A3.5 3.5 0 1012 8.5a3.5 3.5 0 000 7zm7-3.5l-1.6-.93a5.92 5.92 0 00-.36-.86l.46-1.8l-1.77-1.02l-1.34 1.27a6.9 6.9 0 00-.93-.15L12 5l-2.33 2.51c-.32.03-.63.08-.93.15L7.4 6.39L5.63 7.4l.46 1.8c-.14.28-.26.57-.36.86L4.13 12l1.6.93c.09.3.21.59.36.87l-.46 1.8l1.77 1.02l1.34-1.27c.3.07.61.12.93.15L12 19l2.33-2.5c.32-.03.63-.08.93-.15l1.34 1.27l1.77-1.02l-.46-1.8c.15-.28.27-.57.36-.87L19 12z"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.3"
                />
              </svg>
              <span>Accedi</span>
            </button>
          </form>
        </section>

        <section id="admin-panel-view" class="admin-panel-view hidden">
          <div class="admin-toolbar">
            <p>Modalita admin attiva</p>
            <button id="admin-logout" class="ghost-btn" type="button">Esci</button>
          </div>

          <div class="admin-layout">
            <section class="admin-section">
              <div class="section-title-row">
                <div>
                  <p class="eyebrow">Storage</p>
                  <h3>Account Google Drive</h3>
                </div>
              </div>

              <form id="storage-account-form" class="storage-account-form">
                <label>
                  <span>Nome account</span>
                  <input name="label" type="text" maxlength="80" required placeholder="Es. Drive Matematica" />
                </label>
                <label>
                  <span>Email Gmail</span>
                  <input name="email" type="email" maxlength="120" required placeholder="esempio@gmail.com" />
                </label>
                <label class="full-width">
                  <span>Google OAuth Client ID</span>
                  <input name="clientId" type="text" maxlength="240" required placeholder="Client ID del progetto Google" />
                </label>
                <label class="full-width">
                  <span>Google OAuth Client Secret</span>
                  <input name="clientSecret" type="password" maxlength="240" required placeholder="Client secret" />
                </label>
                <label class="full-width">
                  <span>Refresh token</span>
                  <textarea name="refreshToken" rows="3" maxlength="500" required placeholder="Refresh token del Gmail collegato"></textarea>
                </label>
                <button class="primary-btn" type="submit">Aggiungi account</button>
              </form>

              <div id="storage-account-list" class="storage-account-list"></div>
            </section>

            <section class="admin-section">
              <div class="section-title-row">
                <div>
                  <p class="eyebrow">Organizzazione</p>
                  <h3>Materie</h3>
                </div>
              </div>

              <form id="subject-create-form" class="subject-create-form">
                <label>
                  <span>Nuova materia</span>
                  <input name="name" type="text" maxlength="60" required placeholder="Es. Filosofia" />
                </label>
                <label>
                  <span>Colore</span>
                  <input name="color" type="color" value="#0f766e" />
                </label>
                <button class="primary-btn" type="submit">Aggiungi</button>
              </form>

              <div id="subject-admin-list" class="subject-admin-list"></div>
            </section>

            <section class="admin-section">
              <div class="section-title-row">
                <div>
                  <p class="eyebrow">Catalogo</p>
                  <h3>File</h3>
                </div>
              </div>
              <div id="file-admin-list" class="file-admin-list"></div>
            </section>
          </div>
        </section>
      </div>
    </div>

    <div id="toast" class="toast hidden" aria-live="polite"></div>
  </body>
</html>
